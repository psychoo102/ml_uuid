{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 14
  },
  "configurePresets": [
    {
      "name": "win32-debug",
      "displayName": "Windows 32-bit Debug (MTA)",
      "generator": "Visual Studio 17 2022",
      "architecture": "Win32",
      "toolset": "v143",
      "binaryDir": "${projectDir}/build/win32-debug",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${env:VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x86-windows",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_STANDARD": "17"
      }
    },
    {
      "name": "win32-release",
      "displayName": "Windows 32-bit Release (MTA)",
      "inherits": "win32-debug",
      "binaryDir": "${projectDir}/build/win32-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name": "linux-x64-debug",
      "displayName": "Linux x64 Debug",
      "generator": "Ninja",
      "binaryDir": "${projectDir}/build/linux-x64-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_STANDARD": "17",
        "VCPKG_TARGET_TRIPLET": "x64-linux",
        "CMAKE_MAKE_PROGRAM": "/usr/bin/ninja"
      }
    },
    {
      "name": "linux-x64-release",
      "displayName": "Linux x64 Release",
      "inherits": "linux-x64-debug",
      "binaryDir": "${projectDir}/build/linux-x64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "win32-debug",
      "configurePreset": "win32-debug",
      "displayName": "Windows 32-bit Debug"
    },
    {
      "name": "win32-release",
      "configurePreset": "win32-release",
      "displayName": "Windows 32-bit Release"
    },
    {
      "name": "linux-x64-debug",
      "configurePreset": "linux-x64-debug",
      "displayName": "Linux x64 Debug"
    },
    {
      "name": "linux-x64-release",
      "configurePreset": "linux-x64-release",
      "displayName": "Linux x64 Release"
    }
  ]
}